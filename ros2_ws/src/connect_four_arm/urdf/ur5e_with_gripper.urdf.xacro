<?xml version="1.0"?>
<!-- UR5e + UR-to-Robotiq adapter + Robotiq 2F-85 for Gazebo Harmonic -->
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="$(arg name)">

    <!-- ── Arguments (mirror ur_gz.urdf.xacro exactly) ── -->
    <xacro:arg name="name"                    default="ur"/>
    <xacro:arg name="ur_type"                 default="ur5e"/>
    <xacro:arg name="tf_prefix"               default=""/>
    <xacro:arg name="joint_limit_params"      default="$(find ur_description)/config/$(arg ur_type)/joint_limits.yaml"/>
    <xacro:arg name="kinematics_params"       default="$(find ur_description)/config/$(arg ur_type)/default_kinematics.yaml"/>
    <xacro:arg name="physical_params"         default="$(find ur_description)/config/$(arg ur_type)/physical_parameters.yaml"/>
    <xacro:arg name="visual_params"           default="$(find ur_description)/config/$(arg ur_type)/visual_parameters.yaml"/>
    <xacro:arg name="transmission_hw_interface" default=""/>
    <xacro:arg name="safety_limits"           default="false"/>
    <xacro:arg name="safety_pos_margin"       default="0.15"/>
    <xacro:arg name="safety_k_position"       default="20"/>
    <xacro:arg name="simulation_controllers"  default=""/>
    <xacro:arg name="ros_namespace"           default=""/>

    <!-- ── Includes ── -->
    <!-- UR5e arm macro -->
    <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro"/>
    <!-- UR5e Gazebo ros2_control macro (uses gz_ros2_control/GazeboSimSystem) -->
    <xacro:include filename="$(find ur_simulation_gz)/urdf/ur_gz.ros2_control.xacro"/>

    <!-- Robotiq 2F-85 finger macro (links + joints, no ros2_control) -->
    <xacro:include filename="$(find robotiq_description)/urdf/robotiq_2f_85_macro.urdf.xacro"/>
    <!-- UR-to-Robotiq wrist adapter -->
    <xacro:include filename="$(find robotiq_description)/urdf/ur_to_robotiq_adapter.urdf.xacro"/>
    <!-- Gazebo-compatible gripper ros2_control block -->
    <xacro:include filename="$(find connect_four_arm)/urdf/robotiq_gz.ros2_control.xacro"/>

    <!-- ── World / ground plane (same as ur_gz.urdf.xacro) ── -->
    <link name="world"/>

    <link name="ground_plane">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry><box size="5 5 0"/></geometry>
            <material name="ground_white"><color rgba="1 1 1 0.5"/></material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry><box size="5 5 0"/></geometry>
        </collision>
    </link>
    <joint name="ground_plane_joint" type="fixed">
        <origin xyz="0 0 -0.01" rpy="0 0 0"/>
        <parent link="world"/>
        <child link="ground_plane"/>
    </joint>

    <!-- ── UR5e arm ── -->
    <xacro:ur_robot
        name="$(arg name)"
        tf_prefix="$(arg tf_prefix)"
        parent="world"
        joint_limits_parameters_file="$(arg joint_limit_params)"
        kinematics_parameters_file="$(arg kinematics_params)"
        physical_parameters_file="$(arg physical_params)"
        visual_parameters_file="$(arg visual_params)"
        safety_limits="$(arg safety_limits)"
        safety_pos_margin="$(arg safety_pos_margin)"
        safety_k_position="$(arg safety_k_position)"
        force_abs_paths="true">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:ur_robot>

    <!-- ── UR-to-Robotiq adapter (tool0 → ur_to_robotiq_link → gripper_mount_link) ── -->
    <xacro:ur_to_robotiq prefix="" connected_to="tool0"/>

    <!-- ── Robotiq 2F-85 gripper ── -->
    <!--
      include_ros2_control=false: we supply our own gz-compatible block below.
      sim_ignition=false / use_fake_hardware=false: neither flag applies;
      the gz ros2_control block handles Gazebo-side hardware.
    -->
    <xacro:robotiq_gripper
        name="GripperHardwareInterface"
        prefix=""
        parent="gripper_mount_link"
        sim_ignition="false"
        use_fake_hardware="false"
        include_ros2_control="false">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:robotiq_gripper>

    <!-- ── Gripper ros2_control (Gazebo Harmonic) ── -->
    <xacro:robotiq_gz_ros2_control name="GripperHardwareInterface" prefix=""/>

    <!-- ── Gazebo plugin — handles ALL ros2_control blocks (arm + gripper) ── -->
    <gazebo reference="world"/>
    <gazebo>
        <plugin filename="gz_ros2_control-system"
                name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(arg simulation_controllers)</parameters>
            <!-- position_proportional_gain: vel = gain * (cmd - pos) * update_rate (250 Hz)
                 default 0.1 gives 0.022 rad/sim-sec (too slow, ~95 sim-sec per move).
                 2.0 gives ~0.44 rad/sim-sec, converges within ~5 sim-sec. -->
            <position_proportional_gain>2.0</position_proportional_gain>
            <ros>
                <namespace>$(arg ros_namespace)</namespace>
            </ros>
        </plugin>
    </gazebo>

    <!-- ── UR5e ros2_control (arm joints) ── -->
    <xacro:ur_ros2_control
        name="$(arg name)"
        tf_prefix="$(arg tf_prefix)"
        transmission_hw_interface="$(arg transmission_hw_interface)"/>

</robot>

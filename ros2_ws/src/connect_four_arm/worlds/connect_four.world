          <material><ambient>0.85 0.1 0.1 1</ambient><diffuse>0.85 0.1 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ════════════════════════════════════════════════════════════════
         YELLOW PIECES — 7 cylinders at x=0.42, y=-0.126..+0.126 step 0.042
         ════════════════════════════════════════════════════════════════ -->

    <model name="yellow_piece_0">
      <pose>0.42 -0.126 0.0035 0 0 0</pose>
      <link name="link">

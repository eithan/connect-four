        </visual>
      </link>
    </model>

    <model name="yellow_piece_3">
      <pose>0.42 0.000 0.0035 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.010</mass>
          <inertia><ixx>7.21e-7</ixx><iyy>7.21e-7</iyy><izz>1.36e-6</izz>
